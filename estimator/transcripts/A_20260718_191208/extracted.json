{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MovingJobSpec",
  "description": "Canonical structured spec for a residential move. Produced identically by voice interview or document intake. Confirmed by user before any outbound calls are made.",
  "type": "object",
  "required": [
    "origin",
    "destination",
    "move_date",
    "inventory",
    "access_conditions",
    "service_level"
  ],
  "properties": {
    "origin": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "dwelling_type": {
          "type": "string",
          "enum": [
            "apartment",
            "house",
            "condo",
            "townhouse",
            "duplex",
            "mobile_home",
            "dormitory",
            "storage_unit"
          ]
        },
        "floor": {
          "type": "integer"
        },
        "elevator": {
          "type": "boolean"
        }
      },
      "required": [
        "zip",
        "dwelling_type",
        "floor"
      ]
    },
    "destination": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "dwelling_type": {
          "type": "string",
          "enum": [
            "apartment",
            "house",
            "condo",
            "townhouse",
            "duplex",
            "mobile_home",
            "dormitory",
            "storage_unit"
          ]
        },
        "floor": {
          "type": "integer"
        },
        "elevator": {
          "type": "boolean"
        }
      },
      "required": [
        "zip",
        "dwelling_type",
        "floor"
      ]
    },
    "distance_miles": 45,
    "move_date": "[specific date within the next month]",
    "date_flexible": true,
    "inventory": {
      "type": "object",
      "description": "This is what makes an estimate binding rather than bait. Incomplete inventory is the #1 cause of day-of upcharges.",
      "properties": {
        "num_bedrooms": 2,
        "large_items": [
          {
            "name": "queen bed",
            "quantity": 1,
            "requires_disassembly": false
          },
          {
            "name": "dresser",
            "quantity": 1,
            "requires_disassembly": false
          },
          {
            "name": "sofa",
            "quantity": 1,
            "requires_disassembly": false
          },
          {
            "name": "refrigerator",
            "quantity": 1,
            "requires_disassembly": false
          }
        ],
        "estimated_boxes": 20,
        "estimated_cubic_feet": null,
        "estimated_weight_lbs": null,
        "fragile_or_high_value_items": []
      }
    },
    "access_conditions": {
      "type": "object",
      "description": "The hidden-fee triggers: stairs and 'long carry' are the two most common day-of upcharges per the FMCSA data.",
      "properties": {
        "origin_stairs_flights": 2,
        "destination_stairs_flights": 0,
        "origin_long_carry": false,
        "destination_long_carry": false,
        "parking_permit_required": false,
        "narrow_doorways_or_hallways": false
      }
    },
    "service_level": {
      "type": "object",
      "properties": {
        "service_type": "full_service",
        "packing_materials_needed": true,
        "storage_needed": false,
        "storage_duration_days": null,
        "insurance_valuation_coverage": false
      }
    },
    "user_confirmed": true,
    "spec_version_hash": null
  }
}