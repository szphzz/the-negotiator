{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MovingJobSpec",
  "description": "Canonical structured spec for a residential move. Produced identically by voice interview or document intake. Confirmed by user before any outbound calls are made.",
  "type": "object",
  "required": [
    "origin",
    "destination",
    "move_date",
    "inventory",
    "access_conditions",
    "service_level"
  ],
  "properties": {
    "origin": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "dwelling_type": {
          "type": "string",
          "enum": [
            "apartment",
            "house",
            "condo",
            "townhouse",
            "duplex",
            "mobile_home",
            "dormitory",
            "storage_unit"
          ]
        },
        "floor": {
          "type": "integer"
        },
        "elevator": {
          "type": "boolean"
        }
      },
      "required": [
        "zip",
        "dwelling_type",
        "floor"
      ]
    },
    "destination": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "zip": {
          "type": "string"
        },
        "dwelling_type": {
          "type": "string",
          "enum": [
            "apartment",
            "house",
            "condo",
            "townhouse",
            "duplex",
            "mobile_home",
            "dormitory",
            "storage_unit"
          ]
        },
        "floor": {
          "type": "integer"
        },
        "elevator": {
          "type": "boolean"
        }
      },
      "required": [
        "zip",
        "dwelling_type",
        "floor"
      ]
    },
    "distance_miles": {
      "type": "number"
    },
    "move_date": {
      "type": "string",
      "format": "date"
    },
    "date_flexible": {
      "type": "boolean"
    },
    "inventory": {
      "type": "object",
      "description": "This is what makes an estimate binding rather than bait. Incomplete inventory is the #1 cause of day-of upcharges.",
      "properties": {
        "num_bedrooms": {
          "type": "integer"
        },
        "large_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "examples": [
                  "sofa",
                  "piano",
                  "refrigerator",
                  "treadmill"
                ]
              },
              "quantity": {
                "type": "integer"
              },
              "requires_disassembly": {
                "type": "boolean"
              }
            }
          }
        },
        "estimated_boxes": {
          "type": "integer"
        },
        "estimated_cubic_feet": {
          "type": "number"
        },
        "estimated_weight_lbs": {
          "type": "number"
        },
        "fragile_or_high_value_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "access_conditions": {
      "type": "object",
      "description": "The hidden-fee triggers: stairs and 'long carry' are the two most common day-of upcharges per the FMCSA data.",
      "properties": {
        "origin_stairs_flights": {
          "type": "integer"
        },
        "destination_stairs_flights": {
          "type": "integer"
        },
        "origin_long_carry": {
          "type": "boolean",
          "description": "True if truck cannot park within ~75ft of entrance"
        },
        "destination_long_carry": {
          "type": "boolean"
        },
        "parking_permit_required": {
          "type": "boolean"
        },
        "narrow_doorways_or_hallways": {
          "type": "boolean"
        }
      }
    },
    "service_level": {
      "type": "object",
      "properties": {
        "service_type": {
          "type": "string",
          "enum": [
            "full_service",
            "labor_only",
            "packing_included",
            "self_pack"
          ]
        },
        "packing_materials_needed": {
          "type": "boolean"
        },
        "storage_needed": {
          "type": "boolean"
        },
        "storage_duration_days": {
          "type": "integer"
        },
        "insurance_valuation_coverage": {
          "type": "boolean"
        }
      }
    },
    "user_confirmed": {
      "type": "boolean",
      "description": "Must be true before this spec is used in any outbound call. Set only after the user reviews and approves."
    },
    "spec_version_hash": {
      "type": "string",
      "description": "Hash of this object at confirmation time. Every call must log which hash it used, proving verbatim reuse."
    }
  },
  "origin": {
    "address": "Maple Street",
    "zip": "12345",
    "dwelling_type": "apartment",
    "floor": 2,
    "elevator": false
  },
  "destination": {
    "address": "Oak Avenue",
    "zip": "67890",
    "dwelling_type": "apartment",
    "floor": 1,
    "elevator": true
  },
  "distance_miles": 45,
  "move_date": "2023-11-15",
  "date_flexible": false,
  "inventory": {
    "num_bedrooms": 2,
    "large_items": [
      {
        "name": "sofa",
        "quantity": 1,
        "requires_disassembly": false
      },
      {
        "name": "queen bed",
        "quantity": 1,
        "requires_disassembly": true
      },
      {
        "name": "dresser",
        "quantity": 1,
        "requires_disassembly": false
      },
      {
        "name": "refrigerator",
        "quantity": 1,
        "requires_disassembly": false
      }
    ],
    "estimated_boxes": 20,
    "fragile_or_high_value_items": []
  },
  "access_conditions": {
    "origin_stairs_flights": 3,
    "destination_stairs_flights": 0,
    "origin_long_carry": false,
    "destination_long_carry": false
  },
  "service_level": {
    "service_type": "labor_only",
    "packing_materials_needed": false,
    "storage_needed": false
  },
  "user_confirmed": true,
  "spec_version_hash": "not-computed"
}