{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MovingJobSpec",
  "description": "Canonical structured spec for a residential move. Produced identically by voice interview or document intake. Confirmed by user before any outbound calls are made.",
  "type": "object",
  "required": ["origin", "destination", "move_date", "inventory", "access_conditions", "service_level"],
  "properties": {
    "origin": {
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "zip": { "type": "string" },
        "dwelling_type": { "type": "string", "enum": ["apartment", "house", "condo", "storage_unit"] },
        "floor": { "type": "integer" },
        "elevator": { "type": "boolean" }
      },
      "required": ["zip", "dwelling_type", "floor"]
    },
    "destination": {
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "zip": { "type": "string" },
        "dwelling_type": { "type": "string", "enum": ["apartment", "house", "condo", "storage_unit"] },
        "floor": { "type": "integer" },
        "elevator": { "type": "boolean" }
      },
      "required": ["zip", "dwelling_type", "floor"]
    },
    "distance_miles": { "type": "number" },
    "move_date": { "type": "string", "format": "date" },
    "date_flexible": { "type": "boolean" },

    "inventory": {
      "type": "object",
      "description": "This is what makes an estimate binding rather than bait. Incomplete inventory is the #1 cause of day-of upcharges.",
      "properties": {
        "num_bedrooms": { "type": "integer" },
        "large_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "examples": ["sofa", "piano", "refrigerator", "treadmill"] },
              "quantity": { "type": "integer" },
              "requires_disassembly": { "type": "boolean" }
            }
          }
        },
        "estimated_boxes": { "type": "integer" },
        "estimated_cubic_feet": { "type": "number" },
        "estimated_weight_lbs": { "type": "number" },
        "fragile_or_high_value_items": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "access_conditions": {
      "type": "object",
      "description": "The hidden-fee triggers: stairs and 'long carry' are the two most common day-of upcharges per the FMCSA data.",
      "properties": {
        "origin_stairs_flights": { "type": "integer" },
        "destination_stairs_flights": { "type": "integer" },
        "origin_long_carry": { "type": "boolean", "description": "True if truck cannot park within ~75ft of entrance" },
        "destination_long_carry": { "type": "boolean" },
        "parking_permit_required": { "type": "boolean" },
        "narrow_doorways_or_hallways": { "type": "boolean" }
      }
    },

    "service_level": {
      "type": "object",
      "properties": {
        "service_type": { "type": "string", "enum": ["full_service", "labor_only", "packing_included", "self_pack"] },
        "packing_materials_needed": { "type": "boolean" },
        "storage_needed": { "type": "boolean" },
        "storage_duration_days": { "type": "integer" },
        "insurance_valuation_coverage": { "type": "boolean" }
      }
    },

    "user_confirmed": {
      "type": "boolean",
      "description": "Must be true before this spec is used in any outbound call. Set only after the user reviews and approves."
    },
    "spec_version_hash": {
      "type": "string",
      "description": "Hash of this object at confirmation time. Every call must log which hash it used, proving verbatim reuse."
    }
  }
}
